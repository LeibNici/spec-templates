#==============================================================================
.DS_Store
Thumbs.db
*~
*.swp
*.swo

#==============================================================================
# Maven (when scaffold is cloned for a SpringBoot project)
#==============================================================================
target/
*.jar
*.war
*.ear
pom.xml.versionsBackup
release.properties
dependency-reduced-pom.xml

#==============================================================================
# Node / Vite (when scaffold is cloned for a Vue project)
#==============================================================================
node_modules/
dist/
dist-ssr/
*.local
.npm/
.pnpm-store/
.yarn/
.eslintcache
.stylelintcache

#==============================================================================
